# Copy to .env for local dev. All values are env-tunable (TDD A7).

# --- Engine weights (Dev A's keys — final values agreed pre-demo) ---
W_PRICE=0.40
W_LOCATION=0.40
W_AMENITY=0.20
BUDGET_SLACK=500.00
CLEAN_BAND=1
PREMIUM_BOOST=1.15
VERIFIED_BOOST=0.05

# --- Security ---
MAX_OTP_ATTEMPTS=5
OTP_WINDOW_SECONDS=300
JWT_SECRET=change-me-in-production

# --- Persistence: SQLite locally; set the Neon string on Render ---
DATABASE_URL=sqlite:///./hostello.db
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/hostello?sslmode=require

# --- Mocked providers (HLD A1/A2) ---
MOCK_OTP=true
MOCK_KYC=true

# --- Cloudinary (required on Render — no persistent disk). Empty = local disk. ---
CLOUDINARY_URL=
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
